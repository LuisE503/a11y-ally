{
  "name": "a11y-ally-cli",
  "version": "1.0.0",
  "description": "CLI accessibility scanner powered by axe-core with LLM-driven explanations",
  "main": "src/index.js",
  "bin": {
    "a11y-ally": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
